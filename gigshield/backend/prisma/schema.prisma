generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id                    String    @id @default(uuid())
  workerHash            String    @unique
  platforms             String[]
  zone                  String
  city                  String
  weeklyEarningsHistory Float[]
  currentWeeklyPremium  Float
  zoneRiskScore         Float
  seasonalMultiplier    Float
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
}

model Policy {
  id             String   @id @default(uuid())
  workerId       String
  weekStartDate  DateTime
  weekEndDate    DateTime
  premiumAmount  Float
  premiumPaid    Boolean  @default(false)
  coverageActive Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Claim {
  id                  String   @id @default(uuid())
  workerId            String
  policyId            String
  disruptionType      String
  gate1Passed         Boolean
  gate2Passed         Boolean
  fraudCheckPassed    Boolean
  payoutAmount        Float
  payoutStatus        String
  disruptionStartTime DateTime
  disruptionEndTime   DateTime
  hoursLost           Float
  createdAt           DateTime @default(now())
}

model DisruptionEvent {
  id             String    @id @default(uuid())
  zone           String
  eventType      String
  severity       String
  confirmedByApi Boolean
  apiSource      String
  startTime      DateTime
  endTime        DateTime?
  isResolved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model AnomalyArchetype {
  id            String   @id @default(uuid())
  signatureHash String   @unique
  description   String
  confirmations Int      @default(0)
  isAutoTrigger Boolean  @default(false)
  createdAt     DateTime @default(now())
}
